# ─── Server ────────────────────────────────────────
PORT=3000
NODE_ENV=production

# ─── Zendesk ───────────────────────────────────────
ZENDESK_SUBDOMAIN=your-subdomain
ZENDESK_EMAIL=agent@example.com
ZENDESK_API_TOKEN=your-zendesk-api-token
ZENDESK_WEBHOOK_TOKEN=your-webhook-secret
# Bot's Zendesk user ID (numeric). Required for 100% precise agent-intervention detection.
# Find it in Zendesk Admin → Users → click the bot user → ID in URL.
ZENDESK_BOT_USER_ID=0

# ─── OpenRouter / LLM ─────────────────────────────
OPENROUTER_API_KEY=sk-or-xxxx
OPENROUTER_MODEL=openai/gpt-4.1-mini
OPENROUTER_FALLBACK_MODEL=google/gemini-2.5-flash
OPENROUTER_SITE_URL=https://antikvarijat-libar.com
OPENROUTER_SITE_NAME=Antikvarijat Libar Bot

# ─── Embeddings ────────────────────────────────────
EMBEDDING_PROVIDER=openrouter
OPENROUTER_EMBEDDING_MODEL=openai/text-embedding-3-small
# OPENAI_API_KEY=sk-xxxx            # only if EMBEDDING_PROVIDER=openai
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536
EMBEDDING_BATCH_SIZE=64

# ─── Supabase / Vector DB ─────────────────────────
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...
VECTOR_MATCH_COUNT=8
VECTOR_MIN_SCORE=0.68
VECTOR_DOMAIN_AWARE_MIN_SCORE=0.58
VECTOR_FALLBACK_MIN_SCORE=0.55
VECTOR_CONTEXT_ITEMS=5
VECTOR_CHUNK_MAX_CHARS=1200
VECTOR_CHUNK_OVERLAP_CHARS=180
VECTOR_AUTO_SYNC_ENABLED=false
VECTOR_SYNC_INTERVAL_MS=1800000

# ─── OneDrive / SharePoint ────────────────────────
ONEDRIVE_TENANT_ID=
ONEDRIVE_CLIENT_ID=
ONEDRIVE_CLIENT_SECRET=
ONEDRIVE_DRIVE_ID=
ONEDRIVE_SITE_ID=
ONEDRIVE_FOLDER_ID=
ONEDRIVE_FOLDER_URL=
ONEDRIVE_CACHE_TTL_MS=300000
ONEDRIVE_CONTEXT_DOCUMENTS=3
ONEDRIVE_MAX_FILE_SIZE_BYTES=2097152

# ─── Help Center ──────────────────────────────────
HELP_CENTER_CACHE_TTL_MS=300000
HELP_CENTER_CONTEXT_ARTICLES=5
KNOWLEDGE_CONTEXT_ITEMS=5
KNOWLEDGE_MIN_TOP_SCORE=8

# ─── Conversation Memory ─────────────────────────
CONVERSATION_MEMORY_MAX_MESSAGES=10
CONVERSATION_MEMORY_MAX_CHARS=3000

# ─── Tracing / Observability ─────────────────────
TRACE_LOG_ENABLED=true
MAX_TRACE_BUFFER=200

# ─── Security ─────────────────────────────────────
ADMIN_TOKEN=your-admin-secret
RATE_LIMIT_MAX=30
EMBED_ALLOWED_ORIGINS=https://antikvarijat-libar.com,https://www.antikvarijat-libar.com

# ─── Kill Switch ──────────────────────────────────
# When false, bot stops generating AI answers and escalates every conversation.
# For emergency stop without redeploy. Set to true for normal operation.
BOT_ENABLED=true

# ─── Token Budget ─────────────────────────────────
TOKEN_BUDGET_MAX_INPUT=12000
TOKEN_BUDGET_MAX_OUTPUT=1500

# ─── Response Cache ──────────────────────────────
RESPONSE_CACHE_TTL_MS=300000
RESPONSE_CACHE_MAX_ENTRIES=200

# ─── Spam Filter ─────────────────────────────────
ENABLE_EMAIL_SPAM_CLASSIFIER=true
EMAIL_SPAM_AI_MIN_CONFIDENCE=0.75
